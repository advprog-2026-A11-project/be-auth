# Auth service - local .env.example
# Copy this file to `.env` (or use your preferred env loader) and adjust values for local testing.

# Postgres (matches README defaults)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=authdb
DB_USER=authuser
DB_PASSWORD=authpass

# Optional Spring Boot datasource overrides
# Use these if you want to set the full JDBC URL instead of individual props
SPRING_DATASOURCE_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
SPRING_DATASOURCE_USERNAME=${DB_USER}
SPRING_DATASOURCE_PASSWORD=${DB_PASSWORD}

# JPA behavior (dev only)
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Server port
SERVER_PORT=8080

# Frontend origin (helpful for CORS during local dev)
FRONTEND_URL=http://localhost:3000

# Docker Compose DB vars (optional; used by docker-compose.yml)
POSTGRES_USER=authuser
POSTGRES_PASSWORD=authpass
POSTGRES_DB=authdb

# Docker published ports (host -> container)
AUTH_DB_PORT=5433
AUTH_HTTP_PORT=8081
