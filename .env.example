# Example env for `auth` service (do NOT commit real secrets)
# Copy to `.env.local` or set environment vars in your shell before running.

# Preferred: full JDBC URL from Supabase Session Pooler (replace placeholders)
# Use this on IPv4 networks. Direct host db.<project-ref>.supabase.co can be IPv6-only.
# Example (session pooler):
# JDBC_DATABASE_URL=jdbc:postgresql://aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Do NOT put real credentials here. Leave blank and set locally (e.g. in .env.local).
JDBC_DATABASE_URL=

# Alternatively set the pieces below (used only if JDBC_DATABASE_URL not set):
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
# For session pooler use: postgres.<project-ref>
DB_USER=
DB_PASSWORD=

# Supabase auth config (for JWT verification)
SUPABASE_URL=
# Preferred key type for auth requests
SUPABASE_PUBLISHABLE_KEY=
# Optional: backend-only key for admin fallback (never expose to frontend) - yang ngeekspose gw rodok
SUPABASE_SERVICE_ROLE_KEY=
# Optional backward-compat fallback
SUPABASE_ANON_KEY=
# Optionally set explicit JWKS URL
# SUPABASE_JWKS_URL=
AUTH_GOOGLE_REDIRECT_URL=http://localhost:3000/auth/callback
AUTH_SSO_STATE_TTL_SECONDS=600

# Application
FRONTEND_URL=http://localhost:3000
SERVER_PORT=8081
