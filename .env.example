# Example env for `auth` service (do NOT commit real secrets)
# Copy to `.env.local` or set environment vars in your shell before running.

# Preferred: full JDBC URL from Supabase (replace PASSWORD)
# Example (direct DB connection):
# JDBC_DATABASE_URL=jdbc:postgresql://postgres:PASSWORD@db.ubsiynttkoqzdcxpxzbg.supabase.co:5432/postgres?sslmode=require

# Do NOT put real credentials here. Leave blank and set locally (e.g. in .env.local).
JDBC_DATABASE_URL=

# Alternatively set the pieces below (used only if JDBC_DATABASE_URL not set):
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# Supabase auth config (for JWT verification)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optionally set explicit JWKS URL
# SUPABASE_JWKS_URL=

# Application
FRONTEND_URL=http://localhost:3000
SERVER_PORT=8081
