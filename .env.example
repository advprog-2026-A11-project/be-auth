# Example env for `auth` service (do NOT commit real secrets)
# Copy to `.env.local` or set environment vars in your shell before running.

# Preferred: full JDBC URL from Supabase (replace PASSWORD)
# Example (direct DB connection):
# JDBC_DATABASE_URL=

# Or use Supabase transaction pooler (port 6543) if provided.
# Here we use the JDBC URL form with explicit user/password and sslmode.
JDBC_DATABASE_URL=

# Alternatively set the pieces below (used only if JDBC_DATABASE_URL not set):
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# Supabase auth config (for JWT verification)
SUPABASE_URL=
# Optionally set explicit JWKS URL
# SUPABASE_JWKS_URL=https://ubsiynttkoqzdcxpxzbg.supabase.co/auth/v1/.well-known/jwks.json

# Application
FRONTEND_URL=http://localhost:3000
SERVER_PORT=8080
